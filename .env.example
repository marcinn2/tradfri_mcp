# 複製為 .env 後填入實際值（.env 不進 git）

# 必填：gateway 的 LAN IP
TRADFRI_GATEWAY_IP=192.168.x.x

# 選填：預設值如下
# MCP_HOST=0.0.0.0
# MCP_PORT=8765
# PSK_FILE=.tradfri_psk.json
# DEVICES_FILE=devices.json
# ALIASES_FILE=aliases.json

# Telegram 推播通知（選填，未設定時 send_notification tool 靜默略過）
# TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJkkLLmmNNoo
# TELEGRAM_CHAT_ID=123456789

# CoAP OBSERVE 重試間隔（秒，預設 30）
# server 啟動時對每個 alias 建立 CoAP OBSERVE 訂閱，gateway 主動 push 狀態變化。
# 此值只影響訂閱中斷後的重試等待時間，不影響通知的即時性。
# TRADFRI_POLL_INTERVAL=30
