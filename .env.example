# copy to .env and fill in actual values (.env is not committed to git)

# required: gateway LAN IP
TRADFRI_GATEWAY_IP=192.168.x.x

# optional: defaults shown below
# MCP_HOST=0.0.0.0
# MCP_PORT=8765
# PSK_FILE=.tradfri_psk.json
# DEVICES_FILE=devices.json
# ALIASES_FILE=aliases.json

# bearer token auth — every request must then include:
#   Authorization: Bearer <token>
# REQUIRED with the default 0.0.0.0 bind: the server refuses to start on a
# non-loopback bind without it. set it to any hard-to-guess string.
MCP_AUTH_TOKEN=your-secret-token-here

# to run unauthenticated instead, either bind to loopback (MCP_HOST=127.0.0.1)
# or set this override (trusted LAN only) and clear MCP_AUTH_TOKEN above:
# MCP_ALLOW_INSECURE=1
