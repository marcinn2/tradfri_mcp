#!/bin/bash
# tradfri — IKEA TRADFRI light control wrapper
# Simplifies mcporter calls so an 8B LLM can invoke them reliably via exec.
#
# Usage:
#   tradfri <name> on
#   tradfri <name> off
#   tradfri <name> brightness 100
#   tradfri <name> temp warm
#   tradfri <name> temp cool
#   tradfri <name> color red
#   tradfri status <name>
#   tradfri list

set -euo pipefail

# spoken-form → canonical aliases.json name
map_name() {
  case "$1" in
    電視牆|電視牆燈) echo "客廳電視牆" ;;
    沙發) echo "沙發燈" ;;
    光條) echo "玄關光條" ;;
    *) echo "$1" ;;
  esac
}

if [ $# -lt 1 ]; then
  echo "usage: tradfri <name> <action> [arg]"
  echo "actions: on, off, brightness <0-100>, temp warm/cool, color, list, status"
  exit 1
fi

case "$1" in
  列表|list)
    exec mcporter call tradfri.list_aliases
    ;;
  查詢|status)
    if [ $# -lt 2 ]; then
      echo "usage: tradfri status <name>"
      exit 1
    fi
    QNAME=$(map_name "$2")
    exec mcporter call tradfri.get_status "name=$QNAME"
    ;;
  *)
    # first arg is the name, second is the action
    NAME=$(map_name "$1")
    if [ $# -lt 2 ]; then
      echo "usage: tradfri <name> <action>"
      exit 1
    fi
    ACTION="$2"

    # "all lights" → run for every alias in sequence
    if [ "$NAME" = "全部" ] || [ "$NAME" = "全部燈" ] || [ "$NAME" = "所有燈" ]; then
      NAMES="客廳 客廳電視牆 沙發燈 客廳聚光燈 客廳閱讀燈 客廳展示燈 玄關 玄關畫廊 玄關電箱 玄關主燈 融蠟燈 餐廳 餐桌燈 餐廳軌道燈 主臥室 次臥室 走道燈 衣櫥燈 立燈 小夜燈"
      shift 1  # remove NAME
      for N in $NAMES; do
        "$0" "$N" "$@" 2>&1
      done
      exit 0
    fi

    case "$ACTION" in
      開|開燈|on)
        exec mcporter call tradfri.control_by_name "name=$NAME" state=true
        ;;
      關|關燈|off)
        exec mcporter call tradfri.control_by_name "name=$NAME" state=false
        ;;
      亮度|brightness)
        if [ $# -lt 3 ]; then
          echo "usage: tradfri $NAME brightness <0-100>"
          exit 1
        fi
        # percent (0-100) → 0-254
        VAL=$3
        if [ "$VAL" -le 100 ] 2>/dev/null; then
          VAL=$(( VAL * 254 / 100 ))
        fi
        exec mcporter call tradfri.control_by_name "name=$NAME" state=true "brightness=$VAL"
        ;;
      色溫|color_temp|colour_temp|temp)
        if [ $# -lt 3 ]; then
          echo "usage: tradfri $NAME temp warm/cool"
          exit 1
        fi
        case "$3" in
          暖|warm) mcporter call tradfri.control_by_name "name=$NAME" state=true > /dev/null 2>&1; exec mcporter call tradfri.set_color_temp "name=$NAME" direction=warm ;;
          冷|cool) mcporter call tradfri.control_by_name "name=$NAME" state=true > /dev/null 2>&1; exec mcporter call tradfri.set_color_temp "name=$NAME" direction=cool ;;
          *) echo "colour direction: warm or cool"; exit 1 ;;
        esac
        ;;
      顏色|color)
        if [ $# -lt 3 ]; then
          echo "usage: tradfri $NAME color red/green/blue/orange/yellow/purple/pink"
          exit 1
        fi
        # Chinese colour names → English
        case "$3" in
          紅|紅色) COLOR=red ;;
          綠|綠色) COLOR=green ;;
          藍|藍色) COLOR=blue ;;
          橙|橙色) COLOR=orange ;;
          黃|黃色) COLOR=yellow ;;
          紫|紫色) COLOR=purple ;;
          粉|粉色|粉紅) COLOR=pink ;;
          暖白) COLOR=warm_white ;;
          冷白) COLOR=cool_white ;;
          *) COLOR="$3" ;;  # pass English directly
        esac
        mcporter call tradfri.control_by_name "name=$NAME" state=true > /dev/null 2>&1
        exec mcporter call tradfri.set_color "name=$NAME" "color=$COLOR"
        ;;
      *)
        echo "unknown action: $ACTION"
        echo "supported: on, off, brightness <val>, temp warm/cool, color red/green/blue/orange/yellow/purple/pink"
        exit 1
        ;;
    esac
    ;;
esac
